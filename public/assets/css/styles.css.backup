*,*::before,*::after {box-sizing: border-box;}body {margin: 0;font-family: sans-serif;background: #ffffff;color: #0f172a;}.app {min-height: 100vh;display: flex;flex-direction: column;}.app-header {padding: 1.5rem 1.5rem 0.5rem;color: #0f172a;display: flex;justify-content: space-between;align-items: center;flex-wrap: wrap;gap: 1rem;}.header-actions {display: flex;gap: 0.75rem;align-items: center;}.logout-button,.back-button {display: inline-flex;align-items: center;gap: 0.5rem;padding: 0.5rem 1rem;border-radius: 999px;font-size: 0.85rem;text-decoration: none;transition: all 0.15s ease;border: 1px solid rgba(71, 85, 105, 0.4);background: rgba(241, 245, 249, 0.9);color: #0f172a;}.logout-button:hover {background: rgba(239, 68, 68, 0.1);border-color: rgba(239, 68, 68, 0.5);color: #dc2626;}.back-button:hover {background: rgba(59, 130, 246, 0.1);border-color: rgba(59, 130, 246, 0.5);color: #2563eb;}.status-bar {display: inline-flex;flex-wrap: wrap;gap: 0.4rem;margin: 0 0 0.75rem;justify-content: center;}.status-pill {display: inline-flex;align-items: center;padding: 0.25rem 0.6rem;border-radius: 999px;font-size: 0.78rem;background: rgba(241, 245, 249, 0.9);border: 1px solid rgba(71, 85, 105, 0.4);color: #0f172a;}.brand {display: flex;align-items: center;gap: 0.75rem;}.brand-mark {display: inline-flex;align-items: center;justify-content: center;width: 2.5rem;height: 2.5rem;border-radius: 999px;background: radial-gradient(circle at 30% 30%, #38bdf8, #1d4ed8);color: #e5e7eb;font-weight: 700;font-size: 0.95rem;}.brand-text h1 {margin: 0;font-size: 1.25rem;}.brand-text p {margin: 0.2rem 0 0;font-size: 0.85rem;color: #9ca3af;}.app-main {flex: 1;padding: 1.5rem;display: flex;flex-direction: column;gap: 1.5rem;}.hero {max-width: 720px;margin: 0 auto;display: flex;flex-direction: column;align-items: center;text-align: center;gap: 1.5rem;}.orb-container {position: relative;display: flex;flex-direction: column;align-items: center;text-align: center;color: #0f172a;padding: 1rem 0;}.orb {position: relative;width: 280px;height: 280px;border-radius: 50%;display: flex;align-items: center;justify-content: center;background: radial-gradient(circle at 30% 30%, #e2e8f0, #f8fafc 70%);box-shadow:0 0 32px rgba(56, 189, 248, 0.25),0 0 80px rgba(37, 99, 235, 0.15);animation: orbFloat 6s ease-in-out infinite;overflow: visible;}.orb-core {width: 190px;height: 190px;border-radius: 999px;background: radial-gradient(circle at 25% 25%, #ffffff, #e5e7eb 55%, #cbd5f5 80%);box-shadow:0 0 24px rgba(148, 163, 184, 0.7),0 0 40px rgba(148, 163, 184, 0.6);display: flex;align-items: center;justify-content: center;overflow: hidden;}.orb-logo-wrapper {width: 88%;height: 88%;border-radius: 999px;overflow: hidden;}.orb-logo {width: 100%;height: 100%;object-fit: contain;display: block;}.orb-ring {position: absolute;border-radius: 999px;border: 1px solid rgba(191, 219, 254, 0.4);box-shadow: 0 0 18px rgba(56, 189, 248, 0.6);}.orb-ring-1 {width: 230px;height: 230px;animation: orbRingSpin 18s linear infinite;}.orb-ring-2 {width: 190px;height: 190px;border-color: rgba(129, 140, 248, 0.6);animation: orbRingSpinReverse 22s linear infinite;}.orb-pulse {position: absolute;width: 320px;height: 320px;border-radius: 50%;background: radial-gradient(circle, rgba(56, 189, 248, 0.35), transparent 70%);opacity: 0;transform: scale(0.8);pointer-events: none;}.orb-status {margin-top: 1.6rem;max-width: 340px;font-size: 1.05rem;color: #475569;text-shadow:none;}.orb.typing .orb-core {animation: orbCorePulse 0.7s ease-in-out infinite;}.orb.typing .orb-pulse {opacity: 1;animation: orbPulse 1.2s ease-out infinite;}.orb.result-found {box-shadow:0 0 40px rgba(74, 222, 128, 0.7),0 0 80px rgba(34, 197, 94, 0.5);}.orb.no-result {box-shadow:0 0 36px rgba(148, 163, 184, 0.7),0 0 76px rgba(148, 163, 184, 0.5);}.search-card {max-width: 720px;width: 100%;margin: 0 auto;background: rgba(255, 255, 255, 0.95);border-radius: 1rem;padding: 1.25rem 1.5rem 1.5rem;box-shadow:0 20px 25px -5px rgba(0, 0, 0, 0.08),0 8px 10px -6px rgba(0, 0, 0, 0.05);backdrop-filter: blur(12px);border: 1px solid rgba(71, 85, 105, 0.2);}.search-form {display: flex;flex-direction: column;gap: 0.5rem;}.search-label {font-size: 0.85rem;font-weight: 500;color: #475569;}.search-input-wrapper {position: relative;display: flex;align-items: center;}.search-input-wrapper input[type="text"] {width: 100%;padding: 0.75rem 0.9rem 0.75rem 2.5rem;border-radius: 999px;border: 1px solid rgba(71, 85, 105, 0.4);background: rgba(255, 255, 255, 0.95);color: #0f172a;outline: none;font-size: 0.95rem;transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;}.search-input-wrapper input[type="text"]::placeholder {color: #94a3b8;}.search-input-wrapper input[type="text"]:focus {border-color: #38bdf8;box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.4);background: #ffffff;}.search-icon {position: absolute;left: 0.9rem;font-size: 0.95rem;color: #94a3b8;}.search-helper {margin: 0;font-size: 0.8rem;color: #64748b;}.results {max-width: 1040px;width: 100%;margin: 0 auto 2rem;background: rgba(255, 255, 255, 0.95);border-radius: 1rem;padding: 0.75rem 1rem 1rem;border: 1px solid rgba(71, 85, 105, 0.2);box-shadow:0 10px 15px -3px rgba(0, 0, 0, 0.08),0 4px 6px -4px rgba(0, 0, 0, 0.05);color: #0f172a;}.results-placeholder {padding: 0.75rem;font-size: 0.85rem;color: #64748b;}.result-link {display: block;text-decoration: none;color: inherit;transition: transform 0.15s ease, opacity 0.15s ease;}.result-link:hover {transform: translateX(4px);opacity: 0.95;}.result {padding: 0.75rem 0.25rem;border-bottom: 1px solid rgba(71, 85, 105, 0.15);display: flex;flex-direction: column;gap: 0.15rem;cursor: pointer;transition: background-color 0.15s ease;}.result-link:hover .result {background-color: rgba(59, 130, 246, 0.07);border-radius: 0.5rem;}.result:last-child {border-bottom: none;}.result-action {margin-top: 0.5rem;font-size: 0.8rem;color: #2563eb;opacity: 0;transition: opacity 0.15s ease;}.result-link:hover .result-action {opacity: 1;}.result-title {font-weight: 600;font-size: 0.98rem;}.result-meta {font-size: 0.8rem;color: #475569;}.badge {display: inline-flex;align-items: center;padding: 0.2rem 0.55rem;border-radius: 999px;font-size: 0.75rem;font-weight: 500;background: rgba(56, 189, 248, 0.1);color: #0284c7;border: 1px solid rgba(56, 189, 248, 0.4);margin-top: 0.2rem;}.no-results {padding: 0.75rem;font-size: 0.85rem;color: #475569;}.error-message {padding: 0.75rem;border-radius: 0.75rem;background: rgba(239, 68, 68, 0.08);border: 1px solid rgba(239, 68, 68, 0.4);color: #dc2626;font-size: 0.85rem;}.app-footer {padding: 0.75rem 1.5rem 1.25rem;text-align: center;font-size: 0.75rem;color: #64748b;}@media (max-width: 640px) {.app-main {padding: 1rem;}.hero {max-width: 100%;gap: 1.25rem;}.orb-container {order: -1;padding-bottom: 0.5rem;}.search-card {padding: 1rem 1rem 1.25rem;}.results {padding: 0.5rem 0.75rem 0.75rem;}}@keyframes orbFloat {0%, 100% {transform: translateY(0px);}50% {transform: translateY(-12px);}}@keyframes orbCorePulse {0% {transform: scale(1);box-shadow:0 0 35px rgba(56, 189, 248, 0.9),0 0 70px rgba(59, 130, 246, 0.7);}50% {transform: scale(1.05);box-shadow:0 0 45px rgba(56, 189, 248, 1),0 0 90px rgba(96, 165, 250, 0.9);}100% {transform: scale(1);box-shadow:0 0 35px rgba(56, 189, 248, 0.9),0 0 70px rgba(59, 130, 246, 0.7);}}@keyframes orbRingSpin {0% {transform: rotate(0deg);}100% {transform: rotate(360deg);}}@keyframes orbRingSpinReverse {0% {transform: rotate(360deg);}100% {transform: rotate(0deg);}}@keyframes orbPulse {0% {opacity: 0.8;transform: scale(0.9);}100% {opacity: 0;transform: scale(1.2);}}
.detail-page {display: flex;justify-content: center;align-items: flex-start;padding-top: 1rem;}.detail-card {max-width: 800px;width: 100%;margin: 0 auto 2rem;background: rgba(255, 255, 255, 0.98);border-radius: 1rem;padding: 2rem;box-shadow:0 20px 25px -5px rgba(0, 0, 0, 0.1),0 8px 10px -6px rgba(0, 0, 0, 0.06);border: 1px solid rgba(59, 130, 246, 0.3);color: #0f172a;}.detail-header {display: flex;align-items: center;gap: 1.25rem;margin-bottom: 2rem;padding-bottom: 1.5rem;border-bottom: 1px solid rgba(59, 130, 246, 0.2);}.detail-avatar {width: 80px;height: 80px;border-radius: 50%;background: linear-gradient(135deg, #1d4ed8, #38bdf8);display: flex;align-items: center;justify-content: center;font-size: 2rem;font-weight: 700;color: #ffffff;box-shadow: 0 0 20px rgba(56, 189, 248, 0.3);}.detail-title-section h2 {margin: 0;font-size: 1.5rem;color: #0f172a;}.detail-title-section p {margin: 0.25rem 0 0;font-size: 0.9rem;color: #475569;}.detail-content {display: flex;flex-direction: column;gap: 1.5rem;}.detail-section {display: flex;flex-direction: column;gap: 0.75rem;}.detail-section-title {margin: 0;font-size: 1.1rem;color: #1e40af;font-weight: 600;}.detail-grid {display: grid;grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));gap: 1rem;}.detail-item {display: flex;flex-direction: column;gap: 0.25rem;padding: 0.75rem;background: rgba(241, 245, 249, 0.8);border-radius: 0.5rem;border: 1px solid rgba(59, 130, 246, 0.15);}.detail-label {font-size: 0.8rem;color: #475569;font-weight: 500;}.detail-value {font-size: 0.95rem;color: #0f172a;}.detail-value.highlight {color: #2563eb;font-weight: 600;}.detail-value .text-muted {color: #94a3b8;font-style: italic;}.badge-large {padding: 0.35rem 0.75rem;font-size: 0.85rem;}.status-badge {display: inline-flex;align-items: center;padding: 0.3rem 0.7rem;border-radius: 999px;font-size: 0.8rem;font-weight: 600;}.status-active {background: rgba(34, 197, 94, 0.1);color: #16a34a;border: 1px solid rgba(34, 197, 94, 0.4);}.status-inactive {background: rgba(239, 68, 68, 0.1);color: #dc2626;border: 1px solid rgba(239, 68, 68, 0.4);}.detail-summary {padding: 1rem;background: rgba(241, 245, 249, 0.8);border-radius: 0.5rem;border-left: 3px solid #38bdf8;}.detail-summary p {margin: 0;line-height: 1.6;color: #1e293b;}.detail-summary strong {color: #0f172a;font-weight: 600;}.detail-table-wrapper {margin-top: 0.5rem;max-height: 260px;overflow: auto;border-radius: 0.5rem;border: 1px solid rgba(59, 130, 246, 0.2);background: rgba(248, 250, 252, 0.9);}.detail-table {width: 100%;border-collapse: collapse;font-size: 0.85rem;}.detail-table thead {position: sticky;top: 0;background: rgba(241, 245, 249, 0.95);}.detail-table th,.detail-table td {padding: 0.4rem 0.6rem;border-bottom: 1px solid rgba(59, 130, 246, 0.15);}.detail-table th {text-align: left;font-weight: 600;color: #1e293b;}.detail-table-key {width: 35%;color: #475569;font-weight: 500;}.detail-table-value {width: 65%;color: #0f172a;}.detail-actions {margin-top: 2rem;padding-top: 1.5rem;border-top: 1px solid rgba(59, 130, 246, 0.2);display: flex;gap: 1rem;flex-wrap: wrap;}.secondary-button {display: inline-flex;align-items: center;justify-content: center;padding: 0.65rem 1rem;border-radius: 999px;font-size: 0.92rem;font-weight: 600;text-decoration: none;cursor: pointer;background: rgba(241, 245, 249, 0.9);color: #0f172a;border: 1px solid rgba(71, 85, 105, 0.4);transition: all 0.15s ease;}.secondary-button:hover {background: rgba(226, 232, 240, 0.9);border-color: rgba(71, 85, 105, 0.6);color: #0f172a;transform: translateY(-1px);}@media (max-width: 640px) {.app-header {flex-direction: column;align-items: flex-start;}.header-actions {width: 100%;justify-content: flex-start;}.detail-card {padding: 1.5rem;}.detail-header {flex-direction: column;text-align: center;}.detail-grid {grid-template-columns: 1fr;}.detail-actions {flex-direction: column;}.detail-actions .primary-button,.detail-actions .secondary-button {width: 100%;}}
.auth-page {display: flex;justify-content: center;align-items: flex-start;}.auth-card {max-width: 420px;width: 100%;margin: 1.5rem auto 2.5rem;background: rgba(255, 255, 255, 0.98);border-radius: 1rem;padding: 1.75rem 1.75rem 2rem;box-shadow:0 20px 25px -5px rgba(0, 0, 0, 0.1),0 8px 10px -6px rgba(0, 0, 0, 0.06);border: 1px solid rgba(59, 130, 246, 0.3);color: #0f172a;}.auth-illustration {width: 100%;display: flex;justify-content: center;margin-bottom: 0.85rem;}.auth-illustration-img {width: 140px;height: auto;display: block;filter: drop-shadow(0 12px 22px rgba(56, 189, 248, 0.15));opacity: 0.95;}.auth-title {margin: 0 0 0.35rem;font-size: 1.3rem;text-align: center;}.auth-subtitle {margin: 0 0 1.1rem;font-size: 0.9rem;color: #475569;text-align: center;}.auth-form {display: flex;flex-direction: column;gap: 0.85rem;}.form-field {display: flex;flex-direction: column;gap: 0.25rem;}.form-field label {font-size: 0.85rem;color: #1e293b;}.form-field input, .form-field textarea, .form-field select {border-radius: 0.7rem;border: 1px solid rgba(71, 85, 105, 0.4);background: rgba(255, 255, 255, 0.95);color: #0f172a;padding: 0.6rem 0.75rem;font-size: 0.9rem;outline: none;transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;font-family: inherit;}.form-field input::placeholder {color: #94a3b8;}.form-field input:focus, .form-field textarea:focus, .form-field select:focus {border-color: #38bdf8;box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.4);background: #ffffff;}.form-field textarea {resize: vertical;min-height: 120px;}.field-error {font-size: 0.78rem;color: #dc2626;}.auth-actions {margin-top: 0.75rem;display: flex;flex-direction: column;gap: 0.5rem;}.primary-button {border: none;border-radius: 999px;padding: 0.65rem 1rem;font-size: 0.92rem;font-weight: 600;cursor: pointer;background: linear-gradient(135deg, #3b82f6, #60a5fa);color: #ffffff;box-shadow:0 10px 15px -3px rgba(59, 130, 246, 0.4),0 4px 6px -4px rgba(59, 130, 246, 0.3);transition: transform 0.1s ease, box-shadow 0.1s ease, filter 0.1s ease;width: 100%;}.primary-button:hover {filter: brightness(1.15);transform: translateY(-1px);box-shadow:0 12px 18px -3px rgba(59, 130, 246, 0.9),0 6px 8px -4px rgba(59, 130, 246, 0.8);}.primary-button:active {transform: translateY(0);box-shadow:0 5px 10px -3px rgba(59, 130, 246, 0.8),0 2px 4px -4px rgba(59, 130, 246, 0.9);}
.detail-value.salary {color: #10b981;font-weight: 700;font-size: 1.1rem;font-family: 'Courier New', monospace;}.detail-section h3.salary-section {color: #10b981;}
.history-container {display: flex;flex-direction: column;gap: 0.75rem;max-height: 400px;overflow-y: auto;padding: 0.5rem;background: rgba(241, 245, 249, 0.6);border-radius: 0.5rem;border: 1px solid rgba(59, 130, 246, 0.2);}.history-item {background: rgba(255, 255, 255, 0.95);border-radius: 0.5rem;padding: 1rem;border: 1px solid rgba(59, 130, 246, 0.2);transition: all 0.15s ease;}.history-item.current-record {border-color: rgba(34, 197, 94, 0.5);background: rgba(34, 197, 94, 0.05);}.history-item:hover {background: rgba(241, 245, 249, 0.9);border-color: rgba(59, 130, 246, 0.4);}.history-header {display: flex;justify-content: space-between;align-items: center;margin-bottom: 0.75rem;padding-bottom: 0.5rem;border-bottom: 1px solid rgba(59, 130, 246, 0.15);}.history-number {font-size: 0.8rem;color: #475569;font-weight: 600;font-family: 'Courier New', monospace;}.badge-current {background: rgba(34, 197, 94, 0.1);color: #16a34a;border: 1px solid rgba(34, 197, 94, 0.4);font-size: 0.7rem;padding: 0.2rem 0.5rem;}.badge-info {background: rgba(59, 130, 246, 0.1);color: #2563eb;border: 1px solid rgba(59, 130, 246, 0.4);font-size: 0.75rem;padding: 0.25rem 0.6rem;}.history-content {display: flex;flex-direction: column;gap: 0.5rem;}.history-grid {display: grid;grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));gap: 0.75rem;}.history-field {display: flex;flex-direction: column;gap: 0.2rem;}.field-label {font-size: 0.75rem;color: #475569;font-weight: 500;}.field-value {font-size: 0.85rem;color: #0f172a;}
@media (max-width: 640px) {.history-container {max-height: 300px;}.history-grid {grid-template-columns: 1fr;}.history-header {flex-direction: column;align-items: flex-start;gap: 0.5rem;}}
.history-link {display: block;text-decoration: none;color: inherit;transition: all 0.2s ease;}.history-link:hover {transform: translateX(4px);}.history-link:hover .history-item {background: rgba(59, 130, 246, 0.2);border-color: rgba(59, 130, 246, 0.7);}.history-action {margin-top: 0.5rem;padding-top: 0.5rem;border-top: 1px solid rgba(30, 64, 175, 0.2);}.action-text {font-size: 0.75rem;color: #475569;font-style: italic;display: flex;align-items: center;gap: 0.25rem;}.history-link:hover .action-text {color: #2563eb;}.history-item.current-record .action-text {color: #16a34a;}
.history-item.current-record {border-color: rgba(34, 197, 94, 0.6);background: rgba(34, 197, 94, 0.08);box-shadow: 0 0 10px rgba(34, 197, 94, 0.15);}.badge-current {animation: pulse 2s infinite;}@keyframes pulse {0%, 100% {opacity: 1;}50% {opacity: 0.7;}}


/* ========================================
   RESPONSIVE DESIGN - MOBILE FIRST
   ======================================== */

/* Tablets y pantallas medianas */
@media (max-width: 768px) {
    .app-header {
        padding: 1rem;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
    }
    
    .brand h1 {
        font-size: 1.1rem;
    }
    
    .header-actions {
        width: 100%;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .status-pill {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
    }
    
    .logout-button, .back-button {
        font-size: 0.8rem;
        padding: 0.4rem 0.8rem;
    }
    
    .app-main {
        padding: 1rem;
    }
    
    .content-wrapper {
        padding: 1rem !important;
        max-width: 100% !important;
    }
    
    .results {
        padding: 0.75rem !important;
        margin: 0 !important;
    }
    
    .detail-card {
        padding: 1.25rem;
        margin: 1rem auto;
    }
    
    .detail-header {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
    }
    
    .detail-avatar {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
    }
    
    .detail-title-section h2 {
        font-size: 1.25rem;
    }
    
    .detail-grid {
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }
    
    .auth-card {
        margin: 1rem;
        padding: 1.5rem;
        max-width: 100%;
    }
    
    .auth-illustration-img {
        width: 100px;
    }
    
    .auth-title {
        font-size: 1.15rem;
    }
    
    .primary-button {
        padding: 0.7rem 1rem;
        font-size: 0.9rem;
    }
    
    .secondary-button {
        padding: 0.6rem 0.9rem;
        font-size: 0.85rem;
    }
    
    .orb {
        width: 220px;
        height: 220px;
    }
    
    .orb-core {
        width: 150px;
        height: 150px;
    }
    
    .orb-ring-1 {
        width: 180px;
        height: 180px;
    }
    
    .orb-ring-2 {
        width: 150px;
        height: 150px;
    }
}

/* Móviles */
@media (max-width: 480px) {
    .app-header {
        padding: 0.75rem;
    }
    
    .brand h1 {
        font-size: 1rem;
    }
    
    .header-actions {
        flex-direction: column;
        width: 100%;
        align-items: stretch;
    }
    
    .header-actions form {
        width: 100%;
    }
    
    .logout-button, .back-button {
        width: 100%;
        justify-content: center;
    }
    
    .status-pill {
        font-size: 0.7rem;
    }
    
    .app-main {
        padding: 0.75rem;
    }
    
    .content-wrapper {
        padding: 0.75rem !important;
    }
    
    h2 {
        font-size: 1.25rem !important;
    }
    
    .results {
        padding: 0.5rem !important;
        border-radius: 0.75rem;
    }
    
    .result {
        padding: 0.75rem !important;
    }
    
    .result-title {
        font-size: 0.95rem !important;
        line-height: 1.4;
    }
    
    .result-meta {
        font-size: 0.75rem !important;
        flex-direction: column;
        align-items: flex-start !important;
        gap: 0.5rem !important;
    }
    
    .badge {
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
    }
    
    .detail-card {
        padding: 1rem;
        margin: 0.5rem;
        border-radius: 0.75rem;
    }
    
    .detail-section {
        gap: 0.5rem;
    }
    
    .detail-section-title {
        font-size: 1rem;
    }
    
    .detail-item {
        padding: 0.6rem;
    }
    
    .detail-summary {
        padding: 0.75rem;
        font-size: 0.9rem;
    }
    
    .auth-card {
        margin: 0.5rem;
        padding: 1.25rem;
        border-radius: 0.75rem;
    }
    
    .auth-illustration-img {
        width: 80px;
    }
    
    .auth-title {
        font-size: 1.1rem;
    }
    
    .auth-subtitle {
        font-size: 0.85rem;
    }
    
    .form-field label {
        font-size: 0.8rem;
    }
    
    .form-field input,
    .form-field textarea,
    .form-field select {
        font-size: 0.85rem;
        padding: 0.55rem 0.65rem;
    }
    
    .primary-button {
        padding: 0.65rem 0.9rem;
        font-size: 0.85rem;
    }
    
    .secondary-button {
        padding: 0.55rem 0.8rem;
        font-size: 0.8rem;
    }
    
    .auth-actions {
        gap: 0.6rem;
    }
    
    .orb {
        width: 180px;
        height: 180px;
    }
    
    .orb-core {
        width: 120px;
        height: 120px;
    }
    
    .orb-ring-1 {
        width: 150px;
        height: 150px;
    }
    
    .orb-ring-2 {
        width: 120px;
        height: 120px;
    }
    
    .orb-status {
        font-size: 0.9rem;
        margin-top: 1rem;
    }
    
    .search-card {
        padding: 1rem;
        border-radius: 0.75rem;
    }
    
    .search-input-wrapper input[type="text"] {
        font-size: 0.85rem;
        padding: 0.65rem 0.8rem 0.65rem 2.25rem;
    }
    
    .search-icon {
        left: 0.75rem;
        font-size: 0.85rem;
    }
    
    /* Filtros del dashboard */
    .filter-badge {
        font-size: 0.7rem !important;
        padding: 0.25rem 0.5rem !important;
    }
    
    /* Ajustes para formularios en móvil */
    .form-item {
        padding: 1rem !important;
    }
    
    .form-arrow {
        font-size: 1.25rem !important;
    }
    
    /* Tablas responsive */
    .detail-table {
        font-size: 0.75rem;
    }
    
    .detail-table th,
    .detail-table td {
        padding: 0.35rem 0.5rem;
    }
    
    /* Acciones en detalle */
    .detail-actions {
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .detail-actions .primary-button,
    .detail-actions .secondary-button {
        width: 100%;
    }
}

/* Pantallas muy pequeñas */
@media (max-width: 360px) {
    .app-header {
        padding: 0.5rem;
    }
    
    .brand h1 {
        font-size: 0.95rem;
    }
    
    .app-main {
        padding: 0.5rem;
    }
    
    .content-wrapper {
        padding: 0.5rem !important;
    }
    
    h2 {
        font-size: 1.1rem !important;
    }
    
    .results {
        padding: 0.4rem !important;
    }
    
    .result {
        padding: 0.6rem !important;
    }
    
    .result-title {
        font-size: 0.9rem !important;
    }
    
    .detail-card {
        padding: 0.75rem;
        margin: 0.25rem;
    }
    
    .auth-card {
        padding: 1rem;
        margin: 0.25rem;
    }
    
    .badge {
        font-size: 0.65rem;
        padding: 0.2rem 0.4rem;
    }
}

/* Landscape móvil */
@media (max-height: 500px) and (orientation: landscape) {
    .orb {
        width: 150px;
        height: 150px;
    }
    
    .orb-core {
        width: 100px;
        height: 100px;
    }
    
    .orb-ring-1 {
        width: 120px;
        height: 120px;
    }
    
    .orb-ring-2 {
        width: 100px;
        height: 100px;
    }
    
    .auth-card {
        margin: 0.5rem auto;
    }
    
    .auth-illustration-img {
        width: 60px;
    }
}
